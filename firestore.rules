rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin email
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'kabir.a@akn.me.uk';
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Users collection
    match /users/{uid} {
      // Users can read their own doc
      allow read: if isOwner(uid) || isAdmin();
      // Users can create their own doc (on first sign-in)
      allow create: if isOwner(uid);
      // Users can update their own profile fields only (not status/projects)
      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['status', 'projects', 'role']);
      // Only admin can do anything
      allow write: if isAdmin();
    }

    // Projects collection (admin only)
    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Access requests (unauthenticated users can create)
    match /requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
